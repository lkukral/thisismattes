---
interface Props {
  instagramUrl: string;
  tiktokUrl: string;
}

const { instagramUrl, tiktokUrl } = Astro.props;
---

<section class="social-links-section site-container" aria-label="Soziale Netzwerke">
  <nav class="social-nav social-nav--centered" aria-label="Social Links">
    <a href={instagramUrl} aria-label="Instagram Profil" target="_blank" rel="noreferrer noopener">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
        <circle cx="12" cy="12" r="4"></circle>
        <circle cx="17.5" cy="6.5" r="1"></circle>
      </svg>
      <span>Instagram</span>
    </a>
    <a href={tiktokUrl} aria-label="TikTok Profil" target="_blank" rel="noreferrer noopener">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M14 4v8.1a3.9 3.9 0 1 1-3.9-3.9"></path>
        <path d="M14 4c1.2 2 2.9 3 5 3"></path>
      </svg>
      <span>TikTok</span>
    </a>
  </nav>
</section>
